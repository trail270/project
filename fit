#include <stdio.h>

#define MAX 20

void firstFit(int blockSize[], int m, int processSize[], int n) {
    int allocation[MAX];

    for (int i = 0; i < n; i++)
        allocation[i] = -1;

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            if (blockSize[j] >= processSize[i]) {
                allocation[i] = j;
                blockSize[j] -= processSize[i];
                break;
            }
        }
    }

    printf("\nFIRST FIT\n");
    printf("Process\tSize\tBlock\n");

    for (int i = 0; i < n; i++) {
        printf("P%d\t%d\t", i + 1, processSize[i]);

        if (allocation[i] != -1)
            printf("B%d\n", allocation[i] + 1);
        else
            printf("Not Allocated\n");
    }
}

void bestFit(int blockSize[], int m, int processSize[], int n) {
    int allocation[MAX];

    for (int i = 0; i < n; i++)
        allocation[i] = -1;

    for (int i = 0; i < n; i++) {
        int bestIndex = -1;

        for (int j = 0; j < m; j++) {
            if (blockSize[j] >= processSize[i]) {
                if (bestIndex == -1 || blockSize[j] < blockSize[bestIndex])
                    bestIndex = j;
            }
        }

        if (bestIndex != -1) {
            allocation[i] = bestIndex;
            blockSize[bestIndex] -= processSize[i];
        }
    }

    printf("\nBEST FIT\n");
    printf("Process\tSize\tBlock\n");

    for (int i = 0; i < n; i++) {
        printf("P%d\t%d\t", i + 1, processSize[i]);

        if (allocation[i] != -1)
            printf("B%d\n", allocation[i] + 1);
        else
            printf("Not Allocated\n");
    }
}

void worstFit(int blockSize[], int m, int processSize[], int n) {
    int allocation[MAX];

    for (int i = 0; i < n; i++)
        allocation[i] = -1;

    for (int i = 0; i < n; i++) {
        int worstIndex = -1;

        for (int j = 0; j < m; j++) {
            if (blockSize[j] >= processSize[i]) {
                if (worstIndex == -1 || blockSize[j] > blockSize[worstIndex])
                    worstIndex = j;
            }
        }

        if (worstIndex != -1) {
            allocation[i] = worstIndex;
            blockSize[worstIndex] -= processSize[i];
        }
    }

    printf("\nWORST FIT\n");
    printf("Process\tSize\tBlock\n");

    for (int i = 0; i < n; i++) {
        printf("P%d\t%d\t", i + 1, processSize[i]);

        if (allocation[i] != -1)
            printf("B%d\n", allocation[i] + 1);
        else
            printf("Not Allocated\n");
    }
}

void nextFit(int blockSize[], int m, int processSize[], int n) {
    int allocation[MAX];
    int lastPosition = 0;

    for (int i = 0; i < n; i++)
        allocation[i] = -1;

    for (int i = 0; i < n; i++) {
        int count = 0;
        int j = lastPosition;

        while (count < m) {
            if (blockSize[j] >= processSize[i]) {
                allocation[i] = j;
                blockSize[j] -= processSize[i];
                lastPosition = j;
                break;
            }

            j = (j + 1) % m;
            count++;
        }
    }

    printf("\nNEXT FIT\n");
    printf("Process\tSize\tBlock\n");

    for (int i = 0; i < n; i++) {
        printf("P%d\t%d\t", i + 1, processSize[i]);

        if (allocation[i] != -1)
            printf("B%d\n", allocation[i] + 1);
        else
            printf("Not Allocated\n");
    }
}

void copyArray(int source[], int destination[], int size) {
    for (int i = 0; i < size; i++)
        destination[i] = source[i];
}

int main() {
    int m, n;
    int blockSize[MAX], processSize[MAX];
    int tempBlock[MAX];

    printf("Enter number of memory blocks: ");
    scanf("%d", &m);

    printf("Enter size of each memory block:\n");
    for (int i = 0; i < m; i++) {
        printf("Block %d: ", i + 1);
        scanf("%d", &blockSize[i]);
    }

    printf("\nEnter number of processes: ");
    scanf("%d", &n);

    printf("Enter size of each process:\n");
    for (int i = 0; i < n; i++) {
        printf("Process %d: ", i + 1);
        scanf("%d", &processSize[i]);
    }

    copyArray(blockSize, tempBlock, m);
    firstFit(tempBlock, m, processSize, n);

    copyArray(blockSize, tempBlock, m);
    bestFit(tempBlock, m, processSize, n);

    copyArray(blockSize, tempBlock, m);
    nextFit(tempBlock, m, processSize, n);

    copyArray(blockSize, tempBlock, m);
    worstFit(tempBlock, m, processSize, n);

    return 0;
}
