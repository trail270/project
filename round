#include <stdio.h>

#define MAX 20

int queue[MAX];
int front = -1, rear = -1;

// Enqueue
void enqueue(int p) {

    if (rear == MAX - 1) {
        printf("Queue Full\n");
        return;
    }

    if (front == -1)
        front = 0;

    queue[++rear] = p;
}

// Dequeue
int dequeue() {

    if (front == -1 || front > rear)
        return -1;

    return queue[front++];
}

int main() {

    int n, tq;
    int i;

    int at[MAX], bt[MAX], rt[MAX];
    int ct[MAX], tat[MAX], wt[MAX];

    int completed = 0;
    int time = 0;

    float avgWT = 0, avgTAT = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    // Input
    for (i = 0; i < n; i++) {

        printf("\nEnter Arrival Time for P%d: ", i + 1);
        scanf("%d", &at[i]);

        printf("Enter Burst Time for P%d: ", i + 1);
        scanf("%d", &bt[i]);

        rt[i] = bt[i];
    }

    printf("\nEnter Time Quantum: ");
    scanf("%d", &tq);

    // Initially add all processes to queue
    for (i = 0; i < n; i++) {
        enqueue(i);
    }

    printf("\nGantt Chart:\n");

    while (completed < n) {

        int p = dequeue();

        // Skip completed process
        if (rt[p] <= 0)
            continue;

        printf("| P%d ", p + 1);

        // Execute process
        if (rt[p] > tq) {

            time += tq;

            rt[p] -= tq;

            // Add process back to queue
            enqueue(p);

        } else {

            time += rt[p];

            rt[p] = 0;

            completed++;

            ct[p] = time;

            tat[p] = ct[p] - at[p];

            wt[p] = tat[p] - bt[p];

            avgWT += wt[p];

            avgTAT += tat[p];
        }
    }

    printf("|\n");

    // Output
    printf("\nProcess\tAT\tBT\tCT\tTAT\tWT\n");

    for (i = 0; i < n; i++) {

        printf("P%d\t%d\t%d\t%d\t%d\t%d\n",
               i + 1,
               at[i],
               bt[i],
               ct[i],
               tat[i],
               wt[i]);
    }

    printf("\nAverage Waiting Time = %.2f", avgWT / n);

    printf("\nAverage Turnaround Time = %.2f\n", avgTAT / n);

    return 0;
}
