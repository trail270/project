//priority
#include <stdio.h>

#define MAX 20

int queue[MAX];
int front = -1, rear = -1;

void resetQueue()
{
    front = rear = -1;
}

void enqueue(int p)
{

    if (rear == MAX - 1)
    {
        printf("Queue Full\n");
        return;
    }

    if (front == -1)
        front = 0;

    queue[++rear] = p;
}

int dequeue()
{

    if (front == -1 || front > rear)
        return -1;

    return queue[front++];
}

int isInQueue(int p)
{
    int i;

    if (front == -1)
        return 0;

    for (i = front; i <= rear; i++)
    {
        if (queue[i] == p)
            return 1;
    }

    return 0;
}

int dequeueHighestPriority(int priority[], int rt[])
{
    int i;
    int bestIndex = front;

    for (i = front + 1; i <= rear; i++)
    {
        int current = queue[i];
        int best = queue[bestIndex];

        if (priority[current] < priority[best])
        {
            bestIndex = i;
        }
        else if (priority[current] == priority[best])
        {
            if (rt[current] < rt[best])
            {
                bestIndex = i;
            }
        }
    }

    int process = queue[bestIndex];

    for (i = bestIndex; i < rear; i++)
    {
        queue[i] = queue[i + 1];
    }

    rear--;

    if (front > rear)
    {
        front = rear = -1;
    }

    return process;
}

void priorityNonPreemptive()
{
    int n, i, j;
    int at[MAX], bt[MAX], pr[MAX];
    int ct[MAX], tat[MAX], wt[MAX];
    float avgWT = 0, avgTAT = 0;

    resetQueue();

    printf("Enter number of processes: ");
    scanf("%d", &n);

    // Input
    for (i = 0; i < n; i++)
    {

        printf("\nEnter Arrival Time for P%d: ", i + 1);
        scanf("%d", &at[i]);

        printf("Enter Burst Time for P%d: ", i + 1);
        scanf("%d", &bt[i]);

        printf("Enter Priority for P%d: ", i + 1);
        scanf("%d", &pr[i]);

        enqueue(i);
    }

    for (i = front; i <= rear; i++)
    {
        for (j = i + 1; j <= rear; j++)
        {
            if (pr[queue[i]] > pr[queue[j]])
            {
                int temp = queue[i];
                queue[i] = queue[j];
                queue[j] = temp;
            }
        }
    }

    int time = 0;

    printf("\nGantt Chart:\n");

    // Execute processes
    while (front <= rear)
    {

        int p = dequeue();

        if (time < at[p])
            time = at[p];

        printf("| P%d ", p + 1);

        ct[p] = time + bt[p];
        time = ct[p];

        tat[p] = ct[p] - at[p];
        wt[p] = tat[p] - bt[p];

        avgWT += wt[p];
        avgTAT += tat[p];
    }

    printf("|\n");

    // Output Table
    printf("\nProcess\tAT\tBT\tPR\tCT\tTAT\tWT\n");

    for (i = 0; i < n; i++)
    {

        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
               i + 1,
               at[i],
               bt[i],
               pr[i],
               ct[i],
               tat[i],
               wt[i]);
    }

    printf("\nAverage Waiting Time = %.2f", avgWT / n);

    printf("\nAverage Turnaround Time = %.2f\n", avgTAT / n);
}

void priorityPreemptive()
{
    int n, i;
    int at[MAX], bt[MAX], priority[MAX];
    int rt[MAX], ct[MAX], tat[MAX], wt[MAX];
    int completed = 0, time = 0;
    float avgWT = 0, avgTAT = 0;

    resetQueue();

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for (i = 0; i < n; i++)
    {
        printf("Enter Arrival Time, Burst Time and Priority for P%d: ", i + 1);
        scanf("%d %d %d", &at[i], &bt[i], &priority[i]);

        rt[i] = bt[i];
    }

    printf("\nGantt Chart:\n");

    while (completed < n)
    {

        for (i = 0; i < n; i++)
        {
            if (at[i] <= time && rt[i] > 0 && !isInQueue(i))
            {
                enqueue(i);
            }
        }

        if (front == -1)
        {
            time++;
            continue;
        }

        int p = dequeueHighestPriority(priority, rt);

        printf("| P%d ", p + 1);

        rt[p]--;
        time++;

        if (rt[p] > 0)
        {
            enqueue(p);
        }
        else
        {
            completed++;

            ct[p] = time;
            tat[p] = ct[p] - at[p];
            wt[p] = tat[p] - bt[p];

            avgWT += wt[p];
            avgTAT += tat[p];
        }
    }

    printf("|\n");

    printf("\nProcess\tAT\tBT\tPriority\tCT\tTAT\tWT\n");

    for (i = 0; i < n; i++)
    {
        printf("P%d\t%d\t%d\t%d\t\t%d\t%d\t%d\n",
               i + 1,
               at[i],
               bt[i],
               priority[i],
               ct[i],
               tat[i],
               wt[i]);
    }

    printf("\nAverage Waiting Time = %.2f", avgWT / n);
    printf("\nAverage Turnaround Time = %.2f\n", avgTAT / n);
}

int main()
{
    int choice;

    printf("1. Priority Non-Preemptive\n");
    printf("2. Priority Preemptive\n");
    printf("Enter your choice: ");
    scanf("%d", &choice);

    if (choice == 1)
    {
        priorityNonPreemptive();
    }
    else if (choice == 2)
    {
        priorityPreemptive();
    }
    else
    {
        printf("Invalid Choice\n");
    }

    return 0;
}
