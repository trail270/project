//deadlock
#include <stdio.h>

int main()
{
    int NoP, NoR;

    printf("Enter number of processes: ");
    scanf("%d", &NoP);

    printf("Enter number of resources: ");
    scanf("%d", &NoR);

    int Available[NoR];
    int Allocation[NoP][NoR];
    int Request[NoP][NoR];
    int Work[NoR];
    int Finish[NoP];

    printf("\nEnter Available:\n");
    for (int j = 0; j < NoR; j++)
    {
        scanf("%d", &Available[j]);
        Work[j] = Available[j];
    }

    printf("\nEnter Allocation matrix:\n");
    for (int i = 0; i < NoP; i++)
        for (int j = 0; j < NoR; j++)
            scanf("%d", &Allocation[i][j]);

    printf("\nEnter Request matrix:\n");
    for (int i = 0; i < NoP; i++)
        for (int j = 0; j < NoR; j++)
            scanf("%d", &Request[i][j]);

    // Initialize Finish[]
    for (int i = 0; i < NoP; i++)
    {
        int zeroAlloc = 1;

        for (int j = 0; j < NoR; j++)
        {
            if (Allocation[i][j] != 0)
            {
                zeroAlloc = 0;
                break;
            }
        }

        if (zeroAlloc)
            Finish[i] = 1;
        else
            Finish[i] = 0;
    }

    printf("\n=========================================================\n");
    printf("Process\t ALLOCATION\t\t REQUEST\n");
    printf("=========================================================\n");

    for (int i = 0; i < NoP; i++)
    {
        printf("P%d\t ", i);

        for (int j = 0; j < NoR; j++)
            printf("%d ", Allocation[i][j]);

        printf("\t\t ");

        for (int j = 0; j < NoR; j++)
            printf("%d ", Request[i][j]);

        printf("\n");
    }

    printf("\nInitial Work = ");
    for (int j = 0; j < NoR; j++)
        printf("%d ", Work[j]);

    printf("\n");

    int iteration = 1;

    while (1)
    {
        int done = 0;

        printf("\n================ Iteration %d ================\n", iteration);

        printf("Current Work = ");
        for (int j = 0; j < NoR; j++)
            printf("%d ", Work[j]);

        printf("\n");

        for (int i = 0; i < NoP; i++)
        {
            if (Finish[i] == 0)
            {
                int canExecute = 1;

                printf("\nChecking P%d: ", i);

                for (int j = 0; j < NoR; j++)
                {
                    if (Request[i][j] <= Work[j])
                    {
                        continue;
                    }
                    else
                    {
                        canExecute = 0;
                        break;
                    }
                }

                if (canExecute)
                {
                    printf("Request <= Work ---> SATISFIED\n");
                    printf("P%d can execute\n", i);

                    printf("New Work = Work + Allocation[%d] = ", i);

                    for (int j = 0; j < NoR; j++)
                    {
                        Work[j] = Work[j] + Allocation[i][j];
                        printf("%d ", Work[j]);
                    }

                    printf("\n");

                    Finish[i] = 1;
                    done = 1;
                }
                else
                {
                    printf("Request <= Work ---> NOT SATISFIED\n");

                    printf("Request of P%d = ", i);
                    for (int j = 0; j < NoR; j++)
                        printf("%d ", Request[i][j]);

                    printf(" | Work = ");

                    for (int j = 0; j < NoR; j++)
                        printf("%d ", Work[j]);

                    printf("\n");
                }
            }
            else
            {
                printf("\nChecking P%d: Already Finished\n", i);
            }
        }

        if (!done)
        {
            printf("\nNo process could be executed in this iteration.\n");
            break;
        }

        iteration++;
    }

    int deadlock = 0;

    printf("\n=====================================\n");
    printf("Deadlocked Processes:\n");

    for (int i = 0; i < NoP; i++)
    {
        if (Finish[i] == 0)
        {
            printf("P%d ", i);
            deadlock = 1;
        }
    }

    if (deadlock == 0)
        printf("None");

    printf("\n");

    if (deadlock)
        printf("\nSystem is in DEADLOCK\n");
    else
        printf("\nNo Deadlock Detected\n");

    return 0;
}
