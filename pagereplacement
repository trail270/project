// page replacement
#include <stdio.h>

#define MAX 50

int search(int frames[], int frameCount, int page) {
    for (int i = 0; i < frameCount; i++) {
        if (frames[i] == page)
            return 1;
    }
    return 0;
}

void displayFrames(int frames[], int frameCount) {
    for (int i = 0; i < frameCount; i++) {
        if (frames[i] == -1)
            printf("- ");
        else
            printf("%d ", frames[i]);
    }
}

void FIFO(int pages[], int n, int frameCount) {
    int frames[MAX], front = 0;
    int pageFaults = 0;

    for (int i = 0; i < frameCount; i++)
        frames[i] = -1;

    printf("\nFIFO Page Replacement\n");
    printf("Page\tFrames\t\tStatus\n");

    for (int i = 0; i < n; i++) {
        if (!search(frames, frameCount, pages[i])) {
            frames[front] = pages[i];
            front = (front + 1) % frameCount;
            pageFaults++;

            printf("%d\t", pages[i]);
            displayFrames(frames, frameCount);
            printf("\tPage Fault\n");
        } else {
            printf("%d\t", pages[i]);
            displayFrames(frames, frameCount);
            printf("\tHit\n");
        }
    }

    printf("Total Page Faults = %d\n", pageFaults);
}

void LRU(int pages[], int n, int frameCount) {
    int frames[MAX], recent[MAX];
    int pageFaults = 0, time = 0;

    for (int i = 0; i < frameCount; i++) {
        frames[i] = -1;
        recent[i] = 0;
    }

    printf("\nLRU Page Replacement\n");
    printf("Page\tFrames\t\tStatus\n");

    for (int i = 0; i < n; i++) {
        int found = 0;

        for (int j = 0; j < frameCount; j++) {
            if (frames[j] == pages[i]) {
                found = 1;
                recent[j] = ++time;
                break;
            }
        }

        if (!found) {
            int pos = -1;

            for (int j = 0; j < frameCount; j++) {
                if (frames[j] == -1) {
                    pos = j;
                    break;
                }
            }

            if (pos == -1) {
                pos = 0;
                for (int j = 1; j < frameCount; j++) {
                    if (recent[j] < recent[pos])
                        pos = j;
                }
            }

            frames[pos] = pages[i];
            recent[pos] = ++time;
            pageFaults++;

            printf("%d\t", pages[i]);
            displayFrames(frames, frameCount);
            printf("\tPage Fault\n");
        } else {
            printf("%d\t", pages[i]);
            displayFrames(frames, frameCount);
            printf("\tHit\n");
        }
    }

    printf("Total Page Faults = %d\n", pageFaults);
}

int predict(int pages[], int frames[], int n, int index, int frameCount) {
    int farthest = index;
    int pos = -1;

    for (int i = 0; i < frameCount; i++) {
        int j;

        for (j = index; j < n; j++) {
            if (frames[i] == pages[j]) {
                if (j > farthest) {
                    farthest = j;
                    pos = i;
                }
                break;
            }
        }

        if (j == n)
            return i;
    }

    if (pos == -1)
        return 0;
    else
        return pos;
}

void Optimal(int pages[], int n, int frameCount) {
    int frames[MAX];
    int pageFaults = 0;

    for (int i = 0; i < frameCount; i++)
        frames[i] = -1;

    printf("\nOptimal Page Replacement\n");
    printf("Page\tFrames\t\tStatus\n");

    for (int i = 0; i < n; i++) {
        if (!search(frames, frameCount, pages[i])) {
            int pos = -1;

            for (int j = 0; j < frameCount; j++) {
                if (frames[j] == -1) {
                    pos = j;
                    break;
                }
            }

            if (pos == -1)
                pos = predict(pages, frames, n, i + 1, frameCount);

            frames[pos] = pages[i];
            pageFaults++;

            printf("%d\t", pages[i]);
            displayFrames(frames, frameCount);
            printf("\tPage Fault\n");
        } else {
            printf("%d\t", pages[i]);
            displayFrames(frames, frameCount);
            printf("\tHit\n");
        }
    }

    printf("Total Page Faults = %d\n", pageFaults);
}

int main() {
    int n, frameCount;
    int pages[MAX];

    printf("Enter number of pages: ");
    scanf("%d", &n);

    printf("Enter page reference string:\n");
    for (int i = 0; i < n; i++)
        scanf("%d", &pages[i]);

    printf("Enter number of frames: ");
    scanf("%d", &frameCount);

    FIFO(pages, n, frameCount);
    LRU(pages, n, frameCount);
    Optimal(pages, n, frameCount);

    return 0;
}
