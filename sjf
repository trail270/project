#include <stdio.h>

#define MAX 20

int queue[MAX];
int front = -1, rear = -1;

void resetQueue() {
    front = rear = -1;
}

void enqueue(int process) {
    if (rear == MAX - 1) {
        printf("Queue Full\n");
        return;
    }

    if (front == -1)
        front = 0;

    queue[++rear] = process;
}

int dequeue() {
    if (front == -1 || front > rear)
        return -1;

    return queue[front++];
}

int dequeueShortest(int remainingTime[]) {
    int i, minIndex = front;

    for (i = front + 1; i <= rear; i++) {
        if (remainingTime[queue[i]] < remainingTime[queue[minIndex]]) {
            minIndex = i;
        }
    }

    int process = queue[minIndex];

    for (i = minIndex; i < rear; i++) {
        queue[i] = queue[i + 1];
    }

    rear--;

    if (front > rear) {
        front = rear = -1;
    }

    return process;
}

int isInQueue(int p) {
    int i;
    for (i = front; i <= rear; i++) {
        if (queue[i] == p)
            return 1;
    }
    return 0;
}

void sjfNonPreemptive() {
    int n, i, j;
    int at[MAX], bt[MAX], ct[MAX], tat[MAX], wt[MAX];
    float avgWT = 0, avgTAT = 0;

    resetQueue();

    printf("Enter number of processes: ");
    scanf("%d", &n);

    // Input
    for (i = 0; i < n; i++) {
        printf("Enter Arrival Time and Burst Time for P%d: ", i + 1);
        scanf("%d %d", &at[i], &bt[i]);

        enqueue(i);
    }

    // Sort queue according to Burst Time (SJF)
    for (i = front; i <= rear; i++) {
        for (j = i + 1; j <= rear; j++) {

            if (bt[queue[i]] > bt[queue[j]]) {

                int temp = queue[i];
                queue[i] = queue[j];
                queue[j] = temp;
            }
        }
    }

    int time = 0;

    printf("\nGantt Chart:\n");

    // Execute processes
    while (front <= rear) {

        int p = dequeue();

        if (time < at[p])
            time = at[p];

        printf("| P%d ", p + 1);

        ct[p] = time + bt[p];
        time = ct[p];

        tat[p] = ct[p] - at[p];
        wt[p] = tat[p] - bt[p];

        avgWT += wt[p];
        avgTAT += tat[p];
    }

    printf("|\n");

    // Output Table
    printf("\nProcess\tAT\tBT\tCT\tTAT\tWT\n");

    for (i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n",
               i + 1,
               at[i],
               bt[i],
               ct[i],
               tat[i],
               wt[i]);
    }

    printf("\nAverage Waiting Time = %.2f", avgWT / n);
    printf("\nAverage Turnaround Time = %.2f\n", avgTAT / n);
}

void sjfPreemptive() {
    int n, i;
    int at[MAX], bt[MAX], rt[MAX], ct[MAX], tat[MAX], wt[MAX];
    int completed = 0, time = 0;
    float avgWT = 0, avgTAT = 0;

    resetQueue();

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for (i = 0; i < n; i++) {
        printf("Enter Arrival Time and Burst Time for P%d: ", i + 1);
        scanf("%d %d", &at[i], &bt[i]);
        rt[i] = bt[i];
    }

    printf("\nGantt Chart:\n");

    while (completed < n) {

        // Add arrived processes to queue
        for (i = 0; i < n; i++) {
            if (at[i] <= time && rt[i] > 0 && !isInQueue(i)) {
                enqueue(i);
            }
        }

        if (front == -1) {
            time++;
            continue;
        }

        // Select process with shortest remaining time
        int p = dequeueShortest(rt);

        printf("| P%d ", p + 1);

        // Execute for 1 unit time
        rt[p]--;
        time++;

        // If process is not completed, put it back in queue
        if (rt[p] > 0) {
            enqueue(p);
        } else {
            completed++;
            ct[p] = time;

            tat[p] = ct[p] - at[p];
            wt[p] = tat[p] - bt[p];

            avgWT += wt[p];
            avgTAT += tat[p];
        }
    }

    printf("|\n");

    printf("\nProcess\tAT\tBT\tCT\tTAT\tWT\n");

    for (i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n",
               i + 1, at[i], bt[i], ct[i], tat[i], wt[i]);
    }

    printf("\nAverage Waiting Time = %.2f", avgWT / n);
    printf("\nAverage Turnaround Time = %.2f\n", avgTAT / n);
}

int main() {
    int choice;

    printf("1. SJF Non-Preemptive\n");
    printf("2. SJF Preemptive\n");
    printf("Enter your choice: ");
    scanf("%d", &choice);

    switch (choice) {
        case 1:
            sjfNonPreemptive();
            break;

        case 2:
            sjfPreemptive();
            break;

        default:
            printf("Invalid Choice\n");
    }

    return 0;
}
