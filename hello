// hello world
/*
$AMJ000100100002
GD20PD20H
$DTA
Hello World                             
$END
*/

#include <stdio.h>
#include <string.h>
#include <stdbool.h>

char M[400][4], IR[4], R[4];
int IC;
bool C;
int SI;
int PTR;
bool frameUsed[40];

FILE *fin, *fout;
char inputFileName[100];

void init() {
    for (int i = 0; i < 400; i++) {
        for (int j = 0; j < 4; j++) {
            M[i][j] = '_';
        }
    }

    for (int i = 0; i < 40; i++) {
        frameUsed[i] = false;
    }

    for (int i = 0; i < 4; i++) {
        IR[i] = '_';
        R[i] = '_';
    }

    IC = 0;
    C = false;
    SI = 0;
    PTR = 0;
}

void setInputFile(char name[]) {
    strcpy(inputFileName, name);
}

int allocate() {
    for (int i = 0; i < 40; i++) {
        if (!frameUsed[i]) {
            frameUsed[i] = true;
            return i;
        }
    }
    return -1;
}

int addressMap(int VA) {
    int page = VA / 10;
    int offset = VA % 10;

    int frame = (M[PTR + page][2] - '0') * 10 +
                (M[PTR + page][3] - '0');

    return frame * 10 + offset;
}

int getVA() {
    return (IR[2] - '0') * 10 + (IR[3] - '0');
}

void readData() {
    char line[200];

    if (fgets(line, sizeof(line), fin) == NULL)
        return;

    line[strcspn(line, "\n")] = '\0';

    if (strncmp(line, "$END", 4) == 0)
        return;

    int VA = getVA();
    int RA = addressMap(VA);

    int k = 0;

    for (int i = 0; i < strlen(line) && k < 40; i++) {
        M[RA + k / 4][k % 4] = line[i];
        k++;
    }

    SI = 0;
}

void writeData() {
    int VA = getVA();
    int RA = addressMap(VA);

    for (int i = 0; i < 10; i++) {
        for (int j = 0; j < 4; j++) {
            char ch = M[RA + i][j];

            if (ch == '_') {
                fprintf(fout, " ");
                printf(" ");
            } else {
                fprintf(fout, "%c", ch);
                printf("%c", ch);
            }
        }
    }

    fprintf(fout, "\n");
    printf("\n");

    SI = 0;
}

void executeUserProgram() {
    while (1) {
        int RA = addressMap(IC);

        for (int i = 0; i < 4; i++) {
            IR[i] = M[RA][i];
        }

        IC++;

        if (IR[0] == 'H') {
            break;
        }

        if (IR[0] == 'G' && IR[1] == 'D') {
            int VA = getVA();
            int page = VA / 10;

            if (M[PTR + page][0] == '*') {
                int frame = allocate();

                M[PTR + page][0] = '0';
                M[PTR + page][1] = '0';
                M[PTR + page][2] = frame / 10 + '0';
                M[PTR + page][3] = frame % 10 + '0';
            }

            SI = 1;
            readData();
        }
        else if (IR[0] == 'P' && IR[1] == 'D') {
            SI = 2;
            writeData();
        }
    }
}

void load() {
    if (strlen(inputFileName) == 0)
        return;

    fin = fopen(inputFileName, "r");
    fout = fopen("output.txt", "w");

    if (fin == NULL)
        return;

    char line[200];

    while (fgets(line, sizeof(line), fin) != NULL) {
        line[strcspn(line, "\n")] = '\0';

        if (strncmp(line, "$AMJ", 4) == 0) {
            init();

            int frame = allocate();
            PTR = frame * 10;

            for (int i = 0; i < 10; i++) {
                for (int j = 0; j < 4; j++) {
                    M[PTR + i][j] = '*';
                }
            }
        }
        else if (strncmp(line, "$DTA", 4) == 0) {
            IC = 0;
            executeUserProgram();
        }
        else if (strncmp(line, "$END", 4) == 0) {
            continue;
        }
        else {
            int frame = allocate();
            int pageEntry = -1;

            for (int i = 0; i < 10; i++) {
                if (M[PTR + i][0] == '*') {
                    pageEntry = i;
                    break;
                }
            }

            if (pageEntry != -1) {
                M[PTR + pageEntry][0] = '0';
                M[PTR + pageEntry][1] = '0';
                M[PTR + pageEntry][2] = frame / 10 + '0';
                M[PTR + pageEntry][3] = frame % 10 + '0';

                int k = 0;

                for (int i = 0; i < strlen(line) && k < 40; i++) {
                    M[frame * 10 + k / 4][k % 4] = line[i];
                    k++;
                }
            }
        }
    }

    fclose(fin);
    fclose(fout);
}

int main() {
    inputFileName[0] = '\0';

    init();

    setInputFile("input1.txt");
    load();

    return 0;
}
